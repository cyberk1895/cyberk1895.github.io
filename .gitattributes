* text=auto
.gitattributes text eol=lf

# Keep text files used by the blog and GitHub Pages on LF line endings.
*.md text eol=lf
*.markdown text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.txt text eol=lf

# Shell scripts should stay LF on every platform.
*.sh text eol=lf
